__pycache__/
.venv/
.coverage
.pytest_cache/
site-packages/

# Node
node_modules/
.npm/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
*.swp
*~

# Temp
*.tmp
*.bak
